YOUTUBE_FORCE_COOKIELESS=1
YOUTUBE_USE_COOKIES=0
COBALT_API_URL=https://your-primary-cobalt-relay.example/
COBALT_API_URLS=https://your-backup-cobalt-relay-1.example/,https://your-backup-cobalt-relay-2.example/

API_RATE_LIMIT_PER_MINUTE=90
INFO_RATE_LIMIT_PER_MINUTE=45
DOWNLOAD_RATE_LIMIT_PER_MINUTE=12
MEDIA_MAX_CONCURRENT_DOWNLOADS=3
MEDIA_MAX_CONCURRENT_INFO=8
MEDIA_QUEUE_WAIT_SECONDS=8

WEB_CONCURRENCY=1
GUNICORN_THREADS=6
GUNICORN_TIMEOUT=240
GUNICORN_MAX_REQUESTS=250
GUNICORN_MAX_REQUESTS_JITTER=50

# Optional: set this to require X-API-Key for /api/* calls.
# API_KEYS=replace-me,replace-me-2
